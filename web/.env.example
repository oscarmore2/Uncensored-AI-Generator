# ===== AVClubs Web (Next.js) =====

# PostgreSQL 连接串（本地默认：Homebrew 安装的 postgresql@17，当前系统用户免密）
# 本地初始化：
#   brew install postgresql@17 && brew services start postgresql@17
#   /opt/homebrew/opt/postgresql@17/bin/createdb avclubs
# 生产示例：postgresql://user:pass@host:5432/avclubs?sslmode=require
DATABASE_URL="postgresql://localhost:5432/avclubs"

# 会话签名密钥，必须 >= 32 字符。生成方式：
#   openssl rand -hex 32
AUTH_SECRET=""

# 应用公网地址（Stripe 回跳用）
APP_URL="http://localhost:3000"

# Cloudflare Turnstile（登录/注册人机验证）
# Site key 是公开的，须与 Cloudflare 仪表盘里该 widget 一致；Secret 仅后端使用：
TURNSTILE_SITE_KEY="0x4AAAAAAD8ko6Wpne6AI8m0"
TURNSTILE_SECRET=""

# Zen Creator API（https://app.zencreator.pro/api-keys）
# 推荐在管理端 /admin/zen 配置多账户；此处为无激活 DB 账户时的兜底
ZEN_API_KEY=""
# 默认直连 Zen。若部署在 Railway 等机房 IP 被 Cloudflare 拦截（403 Just a moment），
# 请部署 scripts/zen-proxy-worker.js，并把 Base 改成 Worker 地址：
#   ZEN_BASE_URL=https://zen-proxy.yourdomain.com/api/public/v1
ZEN_BASE_URL="https://api.zencreator.pro/api/public/v1"
# 与 Worker 的 PROXY_SECRET 一致（选填）
ZEN_PROXY_SECRET=""
# 可选：若自建中转或日后 Zen 支持 webhook，校验请求头 X-Zen-Webhook-Secret
ZEN_WEBHOOK_SECRET=""

# Stripe（可选兜底；推荐在管理端 /admin/stripe 配置多账户）
# DEMO_MODE=false 时才会走真实 Checkout
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Cryptomus 加密货币支付（https://app.cryptomus.com 商户设置）
# CRYPTOMUS_MERCHANT_ID：商户 UUID
# CRYPTOMUS_PAYMENT_API_KEY：Payment API Key（不是 Payout Key）
CRYPTOMUS_MERCHANT_ID=""
CRYPTOMUS_PAYMENT_API_KEY=""

# 点数套餐（美分）
CREDIT_PACKAGES='{"100": 2900, "500": 12900, "1200": 29900, "3000": 69900}'

# VIP 月费（美分）
VIP_PRICE=9900

# Telegram 通知（选填）：充值成功、新用户注册、生成失败退款、Zen 预算告警
# Bot Token 从 @BotFather 获取；Chat ID 为接收通知的用户/群组 ID
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Zen 消耗估算（选填，管理端看板用；Zen 无余额 API，只能按本地记录估算）
# ZEN_CREDIT_RATIO：本站 1 点数折合多少 Zen credits
# ZEN_MONTHLY_BUDGET：Zen 月度预算（credits），0 表示不设预算不告警
ZEN_CREDIT_RATIO=1
ZEN_MONTHLY_BUDGET=0

# 魔法指令（选填）：Hugging Face Dolphin-Mistral-24B-Venice-Edition
# 推荐在管理端 /admin/hf 配置多 Token；无激活 DB 账户时回退此处
# Token: https://huggingface.co/settings/tokens （需 Inference Providers 权限）
# 模型页: https://huggingface.co/dphn/Dolphin-Mistral-24B-Venice-Edition
# 未配置时创作页不显示「魔法指令」按钮
HF_TOKEN=""
# HF_INFERENCE_BASE_URL="https://router.huggingface.co/v1"
# HF_MAGIC_MODEL="dphn/Dolphin-Mistral-24B-Venice-Edition:featherless-ai"

# 玩物专区（选填）：WaveSpeed.ai
# 推荐在管理端 /admin/wavespeed 配置 Key；无激活 DB 账户时回退此处
# https://wavespeed.ai/accesskey
WAVESPEED_API_KEY=""
# WAVESPEED_BASE_URL="https://api.wavespeed.ai/api/v3"

# 演示模式：true 时充值直接到账、生成用占位图、自动创建 demo 账号
# （demo_user/demo123 普通用户；mod_user/mod123 审核员；admin_user/admin123 管理员）
# 生产环境必须设为 false（否则进程拒绝启动）
DEMO_MODE=false

# 对象存储 OSS（S3 兼容：阿里云 OSS / AWS S3 / MinIO / Cloudflare R2）
# 推荐在管理端 /admin/oss 配置多账户；无激活 DB 账户时回退此处
# 阿里云示例：
#   OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
#   OSS_REGION=oss-cn-hangzhou
#   OSS_BUCKET=your-bucket
#   OSS_PUBLIC_BASE_URL=https://cdn.yourdomain.com
OSS_ENDPOINT=""
OSS_REGION="us-east-1"
OSS_BUCKET=""
OSS_ACCESS_KEY_ID=""
OSS_SECRET_ACCESS_KEY=""
OSS_PUBLIC_BASE_URL=""
OSS_PATH_PREFIX="media"
OSS_MIRROR_ZEN_RESULTS=true
OSS_FORCE_PATH_STYLE=false

# 自动媒体清理：使用 openssl rand -hex 32 生成，与 Railway Cron 服务保持一致
MEDIA_CLEANUP_SECRET=""
# 每次每类最多处理 1–500 条；定时任务会在后续轮次继续处理积压
MEDIA_CLEANUP_BATCH_SIZE=100

# 管理员种子账号（选填，生产可用）：首次登录该用户名时自动创建/提升为 admin
# 密码至少 8 位
SEED_ADMIN_USERNAME=""
SEED_ADMIN_PASSWORD=""
