generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int       @id @default(autoincrement())
  username         String    @unique
  hashedPassword   String
  role             String    @default("user") // user | moderator | admin
  balance          Int       @default(20)
  isVip            Boolean   @default(false)
  vipExpiresAt     DateTime?
  vipTierId        Int?
  playthingAccess  Boolean   @default(false) // 玩物专区单独授权
  disabledAt       DateTime? // 封禁时间；非空表示禁止登录且会话失效
  acceptedTermsAt  DateTime?
  termsVersion     String?
  birthDate        DateTime?
  ageVerifiedAt    DateTime?
  adultModeEnabled Boolean   @default(false)
  createdAt        DateTime  @default(now())

  generations           Generation[]
  transactions          Transaction[]
  cryptoPayments        CryptoPayment[]
  featuredWorks         PublicWork[]
  vipTier               VipTier?               @relation(fields: [vipTierId], references: [id], onDelete: SetNull)
  waveSpeedGenerations  WaveSpeedGeneration[]
  mediaAssets           MediaAsset[]
}

/** Cryptomus 商户配置：Merchant ID 与 Payment API Key 一一对应；同一时间最多一个 isActive=true */
model CryptomusMerchant {
  id                 Int      @id @default(autoincrement())
  label              String // 管理端备注名，如「主商户」「备用」
  merchantId         String   @unique // Cryptomus Merchant UUID
  paymentApiKeyEnc   String // AES-256-GCM 加密后的 Payment API Key
  isActive           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  payments CryptoPayment[]
}

model CryptoPayment {
  id            Int      @id @default(autoincrement())
  userId        Int
  orderId       String   @unique
  invoiceUuid   String?
  credits       Int
  amountUsdCents Int
  status        String   @default("check")
  txid          String?
  network       String?
  payerCurrency String?
  credited      Boolean  @default(false)
  merchantRefId Int? // 创建订单时使用的 CryptomusMerchant.id
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User               @relation(fields: [userId], references: [id])
  merchant CryptomusMerchant? @relation(fields: [merchantRefId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

/** Zen Creator 账户：API Key 加密存储；同一时间最多一个 isActive=true */
model ZenAccount {
  id                  Int       @id @default(autoincrement())
  label               String // 管理端备注名
  apiKeyEnc           String // zc_live_… AES-256-GCM 加密
  isActive            Boolean   @default(false)
  lastKnownBalance    Int? // 最近一次从 Zen GET /balance 同步的 credits
  lastBalanceSyncedAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  generations Generation[]
}

model Generation {
  id             Int       @id @default(autoincrement())
  userId         Int
  mode           String
  prompt         String
  negativePrompt String?
  params         String
  zenJobId       String? // 对应 Zen Creator 的 generation_id（taskId）
  zenAccountId   Int? // 创建该任务时使用的 ZenAccount
  status         String    @default("pending") // pending|queued|processing|succeeded|partial|failed
  progress       Int       @default(0) // 0-100，来自 Zen 轮询
  zenError       String? // Zen 返回的失败原因
  resultUrls     String?
  cost           Int // 本站用户扣点
  zenCreditsCost Int? // 估算或记录的 Zen 侧消耗（成功时按本站 cost×系数）
  deletedAt      DateTime?
  visibility     String    @default("private") // private | featured | hidden
  isAdult        Boolean   @default(false)
  safetyCategories String  @default("[]")
  ownerVipAtCreation Boolean @default(false)
  retentionAssigned  Boolean @default(false)
  mediaExpiresAt DateTime?
  mediaDeletedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  zenAccount ZenAccount? @relation(fields: [zenAccountId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([deletedAt, status, createdAt])
  @@index([zenJobId])
  @@index([zenAccountId, createdAt])
  @@index([mediaExpiresAt, mediaDeletedAt])
}

model PublicWork {
  id                 Int      @id @default(autoincrement())
  title              String?
  mode               String
  prompt             String
  negativePrompt     String?
  params             String   @default("{}")
  mediaUrl           String
  thumbUrl           String?
  source             String // user_feature | zen_import
  sourceGenerationId Int?
  sourceZenJobId     String?
  sortOrder          Int      @default(0)
  isPublished        Boolean  @default(true)
  isAdult            Boolean  @default(false)
  featuredById       Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  featuredBy User? @relation(fields: [featuredById], references: [id])

  @@index([isPublished, isAdult, sortOrder, createdAt])
}

/** 自动清理策略：按媒体类型、生成渠道和创建时会员状态区分 */
model MediaCleanupPolicy {
  id            Int      @id @default(autoincrement())
  mediaType     String   // upload | generated
  channel       String   // all | zen | wavespeed
  audience      String   // all | non_vip | vip
  retentionDays Int?     // null = 永不过期
  updatedAt     DateTime @updatedAt

  @@unique([mediaType, channel, audience])
}

/** 上传接口产生的一次性输入媒体；生成结果由 Generation 表管理 */
model MediaAsset {
  id             Int       @id @default(autoincrement())
  userId         Int
  kind           String    // upload
  channel        String    // wavespeed
  url            String
  objectKey      String?
  contentType    String?
  bytes          Int?
  sourceId       Int?
  retentionAssigned Boolean @default(false)
  expiresAt      DateTime?
  deletedAt      DateTime?
  deleteAttempts Int       @default(0)
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt, deletedAt])
  @@index([userId, createdAt])
  @@index([sourceId])
}

model MediaCleanupRun {
  id          Int       @id @default(autoincrement())
  dryRun      Boolean   @default(false)
  status      String    @default("running")
  scanned     Int       @default(0)
  deleted     Int       @default(0)
  failed      Int       @default(0)
  detail      String    @default("{}")
  startedAt   DateTime  @default(now())
  completedAt DateTime?
}

/** Stripe 账户配置：Secret Key + Webhook Secret 成对；同一时间最多一个 isActive=true */
model StripeAccount {
  id                Int      @id @default(autoincrement())
  label             String // 管理端备注名
  publishableKey    String? // pk_… 可公开，明文存储（选填）
  secretKeyEnc      String // sk_… AES-256-GCM 加密
  webhookSecretEnc  String // whsec_… AES-256-GCM 加密
  isActive          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transactions Transaction[]
}

/** 对象存储账户（S3 兼容 API）；同一时间最多一个 isActive=true */
model OssAccount {
  id                 Int      @id @default(autoincrement())
  label              String
  provider           String   @default("s3") // s3 | aliyun | minio | r2
  endpoint           String
  region             String   @default("us-east-1")
  bucket             String
  accessKeyId        String
  secretAccessKeyEnc String
  publicBaseUrl      String?
  pathPrefix         String   @default("media")
  mirrorZenResults   Boolean  @default(true)
  forcePathStyle     Boolean  @default(false)
  isActive           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

/** Hugging Face Token：魔法指令（Dolphin）；同一时间最多一个 isActive=true */
model HfAccount {
  id          Int      @id @default(autoincrement())
  label       String
  apiTokenEnc String // hf_… AES-256-GCM
  baseUrl     String? // 空则用 env.HF_INFERENCE_BASE_URL
  magicModel  String? // 空则用 env.HF_MAGIC_MODEL
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/** 生成产品 SKU：mode + Zen 模型 + 变体 → 扣点 */
model GenerationProduct {
  id                   Int      @id @default(autoincrement())
  mode                 String // txt2img | txt2vid | img2img | img2vid | undress
  zenTool              String
  zenModel             String
  variantKey           String   @default("") // undress: female|male|couple；其它为空串
  label                String
  creditCost           Int
  batchFourMultiplier  Float    @default(1.5)
  isActive             Boolean  @default(true)
  isDefault            Boolean  @default(false)
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([mode, zenModel, variantKey])
  @@index([mode, isActive, sortOrder])
}

/** 模式 UI 参数 → Zen input 字段映射 */
model ModeParamMapping {
  id        Int      @id @default(autoincrement())
  mode      String
  uiKey     String // ratio | quality | style | duration | resolution …
  zenPath   String // 相对 Zen input 的字段名
  valueMap  String? // JSON object，空则原样传递
  options   String? // JSON array [{value,label}]
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([mode, uiKey])
  @@index([mode, enabled, sortOrder])
}

/** 充值套餐：点数 ↔ 美分 */
model CreditPackage {
  id         Int      @id @default(autoincrement())
  credits    Int
  priceCents Int
  label      String
  badge      String?
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([credits])
  @@index([isActive, sortOrder])
}

/** VIP 等级：折扣率 discountBps（1000 = 10% off） */
model VipTier {
  id               Int       @id @default(autoincrement())
  code             String    @unique
  name             String
  rank             Int       @default(0)
  discountBps      Int       @default(0)
  playthingAccess  Boolean   @default(false) // 该等级 VIP 可进玩物专区
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  plans VipPlan[]
  users User[]
}

/** VIP 可售套餐：绑定等级 + 月费 + 赠点 */
model VipPlan {
  id            Int      @id @default(autoincrement())
  tierId        Int
  label         String
  priceCents    Int
  bonusCredits  Int      @default(0)
  durationDays  Int      @default(30)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tier VipTier @relation(fields: [tierId], references: [id], onDelete: Restrict)

  @@index([isActive, sortOrder])
}

model Transaction {
  id              Int      @id @default(autoincrement())
  userId          Int
  type            String
  amount          Int
  priceCents      Int?
  stripePaymentId String?
  method          String?
  stripeAccountRefId Int? // 创建 Checkout 时使用的 StripeAccount.id
  createdAt       DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id])
  stripeAccount StripeAccount? @relation(fields: [stripeAccountRefId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

/** 管理端操作审计：人工入账、VIP、余额、角色、封禁等 */
model AdminAuditLog {
  id         Int      @id @default(autoincrement())
  adminId    Int
  action     String // crypto_manual_credit | user_vip | user_balance | user_role | user_disable | mod_grant | mod_toggle
  targetType String?
  targetId   String?
  detail     String? // JSON
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([action])
}

/** 支付 Webhook 事件日志：Stripe / Cryptomus */
model WebhookEventLog {
  id         Int      @id @default(autoincrement())
  provider   String // stripe | cryptomus
  eventType  String?
  externalId String?
  status     String // ok | ignored | error
  detail     String?
  createdAt  DateTime @default(now())

  @@index([provider, createdAt])
}

/** WaveSpeed API Key：同一时间最多一个 isActive=true */
model WaveSpeedAccount {
  id        Int      @id @default(autoincrement())
  label     String
  apiKeyEnc String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  generations WaveSpeedGeneration[]
}

/** WaveSpeed 全库模型缓存（同步自 GET /models） */
model WaveSpeedCatalogModel {
  id              Int       @id @default(autoincrement())
  modelId         String    @unique
  name            String
  type            String    @default("")
  description     String    @default("")
  basePriceUsd    Float     @default(0)
  lastUnitPriceUsd Float?
  thumbnailUrl    String?
  apiSchema       String? // JSON
  syncedAt        DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  product WaveSpeedProduct?

  @@index([type])
  @@index([name])
}

/** 玩物专区上架 SKU（本站定价，不吃 VIP 折扣） */
model WaveSpeedProduct {
  id                   Int      @id @default(autoincrement())
  modelId              String   @unique
  catalogModelId       Int?     @unique
  label                String
  creditCost           Int
  isActive             Boolean  @default(true)
  isRecommended        Boolean  @default(false)
  sortOrder            Int      @default(100)
  paramSchemaOverride  String?
  paramPolicy          String? // JSON：时长档位、媒体 MIME/尺寸约束等
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  catalogModel WaveSpeedCatalogModel? @relation(fields: [catalogModelId], references: [id], onDelete: SetNull)
  generations  WaveSpeedGeneration[]

  @@index([isActive, isRecommended, sortOrder])
}

/** 玩物专区生成任务 */
model WaveSpeedGeneration {
  id           Int       @id @default(autoincrement())
  userId       Int
  productId    Int
  prompt       String    @default("")
  params       String    @default("{}")
  externalId   String?
  wsAccountId  Int?
  status       String    @default("pending") // pending|processing|succeeded|failed
  progress     Int       @default(0)
  error        String?
  resultUrls   String?
  cost         Int
  isAdult      Boolean   @default(false)
  safetyCategories String @default("[]")
  ownerVipAtCreation Boolean @default(false)
  retentionAssigned  Boolean @default(false)
  mediaExpiresAt DateTime?
  mediaDeletedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user      User              @relation(fields: [userId], references: [id])
  product   WaveSpeedProduct  @relation(fields: [productId], references: [id])
  wsAccount WaveSpeedAccount? @relation(fields: [wsAccountId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([externalId])
  @@index([status, createdAt])
  @@index([mediaExpiresAt, mediaDeletedAt])
}
