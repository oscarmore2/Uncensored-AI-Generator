# AVClubs Backend Environment
DATABASE_URL=sqlite:///./avclubs.db

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60*24*7

# Zen Creator API (get from https://app.zencreator.pro/api-keys)
ZEN_API_KEY=
ZEN_BASE_URL=https://api.zencreator.pro/api/public/v1

# Stripe (test keys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Credit packages (price in cents for Stripe)
CREDIT_PACKAGES='{"100": 2900, "500": 12900, "1200": 29900, "3000": 69900}'

# VIP monthly price (cents)
VIP_PRICE=9900

# Demo mode (set to false in production)
DEMO_MODE=true